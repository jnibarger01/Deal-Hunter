# Copy to config/.env and customize.

# Telegram/OpenClaw message target (chat id, @handle, etc.)
TELEGRAM_TARGET=

# Dry-run mode (1 = do not send outbound messages)
DRY_RUN=1

# Optional timezone override (default: system local timezone)
TZ=America/Chicago

# If gog commands differ on your machine, override these.
GOG_GMAIL_CMD="gog gmail list --format json"
GOG_CAL_CMD="gog calendar today --format json"

# Urgency behavior
URGENT_THRESHOLD=7.0
LOOKBACK_HOURS=36

# Paths (normally leave as-is)
STATE_DIR=./state
NOISE_SENDERS_FILE=./rules/noise_senders.txt
DB_PATH=./state/automation.db
OPENCLAW_BIN=openclaw
