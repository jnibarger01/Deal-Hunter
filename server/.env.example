# Server Configuration
# Placeholder values only. Do not commit real credentials.

NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://dealhunter:dealhunter_dev_password@localhost:5433/dealhunter?schema=public"

# Security
# Generate strong secrets with: openssl rand -hex 32
JWT_SECRET=change-me-32-characters-minimum-000000
API_KEY=change-me-32-characters-minimum-111111
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
AUTH_REQUIRE_VERIFIED_EMAIL=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Frontend links for verification/reset emails
FRONTEND_URL=http://localhost:5173

# API Keys (External Services)
# Leave empty unless intentionally testing that integration.
GEMINI_API_KEY=
EBAY_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_ENVIRONMENT=PRODUCTION
EBAY_APP_ID=
FACEBOOK_API_KEY=

# SMTP (required for staging/production; placeholders only)
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.invalid

# Single-operator ingest token
# When set, POST /api/v1/deals/ingest[/craigslist] accepts requests that send
# `X-Operator-Token: <value>` instead of an admin JWT. Leave empty to require
# the admin JWT flow. Generate with: openssl rand -hex 32
OPERATOR_INGEST_TOKEN=change-me-32-characters-minimum-222222
OPERATOR_SECRET_KEY=change-me-32-characters-minimum-333333
MARKETPLACE_DELETE_TOKEN=change-me-32-characters-minimum-444444

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# CORS / runtime
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
TRUST_PROXY=1
LOG_LEVEL=info

# Craigslist RSS ingest (optional, disabled by default)
CRAIGSLIST_RSS_URLS=
CRAIGSLIST_MAX_PER_FEED=50
CRAIGSLIST_INGEST_INTERVAL_MINUTES=30
CRAIGSLIST_SCHEDULER_ENABLED=false
