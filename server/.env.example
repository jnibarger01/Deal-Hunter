# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://dealhunter:dealhunter_dev_password@localhost:5433/dealhunter?schema=public"

# Security
# Generate a strong secret with: openssl rand -hex 64
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
AUTH_REQUIRE_VERIFIED_EMAIL=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Frontend links for verification/reset emails
FRONTEND_URL=http://localhost:5173

# API Keys (External Services)
GEMINI_API_KEY=your-gemini-api-key
# Preferred eBay credential setup for live Browse API:
# - production/staging: set EBAY_CLIENT_ID + EBAY_CLIENT_SECRET so the server can mint fresh application tokens
# - fallback: set EBAY_APP_ID for the older Finding API read path
# - local debugging only: EBAY_API_KEY may hold a short-lived OAuth access token (starts with v^1.1#), but eBay stays degraded once that token expires
EBAY_API_KEY=your-ebay-api-key-or-short-lived-token
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_OAUTH_ENVIRONMENT=PRODUCTION
# Legacy fallback (deprecated, still supported for Finding API only):
EBAY_APP_ID=your-ebay-app-id
FACEBOOK_API_KEY=your-facebook-api-key

# SMTP (required for staging/production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM=no-reply@dealhunter.app

# Single-operator ingest token
# When set, POST /api/v1/deals/ingest[/craigslist] accepts requests that send
# `X-Operator-Token: <value>` instead of an admin JWT. Leave empty to require
# the admin JWT flow. Generate with: openssl rand -hex 32
OPERATOR_INGEST_TOKEN=replace-with-64-hex-characters

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# CORS
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=1
LOG_LEVEL=info

# Craigslist RSS ingest (optional)
# Comma-separated feed URLs, example:
# CRAIGSLIST_RSS_URLS=https://kansascity.craigslist.org/search/sss?format=rss,https://wichita.craigslist.org/search/sss?format=rss
CRAIGSLIST_RSS_URLS=
CRAIGSLIST_MAX_PER_FEED=50
CRAIGSLIST_INGEST_INTERVAL_MINUTES=30
CRAIGSLIST_SCHEDULER_ENABLED=false
