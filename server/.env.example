# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://dealhunter:dealhunter_dev_password@localhost:5432/dealhunter?schema=public"

# Security
# Generate a strong secret with: openssl rand -hex 64
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
AUTH_REQUIRE_VERIFIED_EMAIL=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Frontend links for verification/reset emails
FRONTEND_URL=http://localhost:5173

# API Keys (External Services)
GEMINI_API_KEY=your-gemini-api-key
EBAY_API_KEY=your-ebay-api-key
FACEBOOK_API_KEY=your-facebook-api-key

# SMTP (required for staging/production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_FROM=no-reply@dealhunter.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
