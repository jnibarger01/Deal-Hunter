datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Deal {
  id          String   @id @default(cuid())
  source      String
  sourceId    String
  title       String
  description String?
  price       Decimal
  condition   String?
  category    String
  location    String?
  region      String?
  url         String?
  status      ListingStatus @default(active)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  samples   MarketSample[]
  tmvResult TMVResult?
  score     Score?

  @@unique([source, sourceId])
  @@index([status, createdAt])
  @@index([category, createdAt])
  @@index([region])
}

model MarketSample {
  id            String   @id @default(cuid())
  dealId        String
  observedPrice Decimal
  observedAt    DateTime
  source        String
  status        ListingStatus @default(sold)
  condition     String?
  listedAt      DateTime?
  soldAt        DateTime?
  daysToSell    Int?
  location      String?
  region        String?
  title         String?
  description   String?
  createdAt     DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, observedAt])
  @@index([source, observedAt])
  @@index([status, observedAt])
}

model TMVResult {
  dealId              String   @id
  tmv                 Decimal
  confidence          Decimal
  sampleCount         Int
  volatility          Decimal
  liquidityScore      Decimal
  estimatedDaysToSell Int?
  calculatedAt        DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([calculatedAt])
}

model Score {
  dealId         String   @id
  profitMargin   Decimal
  velocityScore  Decimal
  riskScore      Decimal
  compositeRank  Decimal
  calculatedAt   DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([compositeRank])
  @@index([calculatedAt])
}

model MarketplaceSync {
  marketplace  String   @id
  lastSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CategoryConfig {
  category        String  @id
  decayRate       Decimal
  minSamples      Int     @default(8)
  freshnessWindow Int     @default(180)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ListingStatus {
  active
  sold
  expired
}
