{
    "name": "deal-hunter",
    "version": "1.0.0",
    "private": true,
    "description": "Deal Hunter - The Bloomberg Terminal for flippers",
    "workspaces": [
        "server",
        "frontend",
        "mcp"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
        "dev:server": "npm run dev --workspace server",
        "dev:frontend": "npm run dev --workspace frontend",
        "build": "concurrently \"npm run build:server\" \"npm run build:frontend\" \"npm run build:mcp\"",
        "build:server": "npm run build --workspace server",
        "build:frontend": "npm run build --workspace frontend",
        "build:mcp": "npm run build --workspace mcp",
        "start": "npm start --workspace server",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:build": "docker compose build"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "@google/genai": "^1.38.0"
    }
}
